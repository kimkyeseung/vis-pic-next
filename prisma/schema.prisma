generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── AR 콘텐츠 (기존 테이블 유지) ───

model AccessLog {
  id          String    @id
  projectId   String
  accessedAt  DateTime  @default(now())
  arContent   ArContent @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, accessedAt])
  @@map("access_logs")
}

model ArContent {
  id                  String      @id
  folderId            String      @unique
  videoFileId         String?
  previewVideoFileId  String?
  targetFileId        String?
  targetImageFileId   String?
  width               Float?      @default(1)
  height              Float?      @default(1)
  title               String?
  description         String?
  chromaKeyColor      String?
  flatView            Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime
  highPrecision       Boolean     @default(false)
  mode                String      @default("ar")
  videoPositionX      Float?
  videoPositionY      Float?
  videoScale          Float?
  cameraResolution    String      @default("fhd")
  videoQuality        String      @default("low")
  chromaKeySimilarity Float?
  chromaKeySmoothness Float?
  overlayImageFileId  String?
  overlayLinkUrl      String?
  guideImageFileId    String?
  thumbnailBase64     String?
  filterMinCF         Float?
  filterBeta          Float?
  missTolerance       Int?
  matrixLerpFactor    Float?
  accessLogs          AccessLog[]
  mediaItems          MediaItem[]

  @@index([createdAt(sort: Desc)])
  @@map("ar_contents")
}

model MediaItem {
  id                  String    @id
  projectId           String
  type                String
  mode                String
  fileId              String
  previewFileId       String?
  positionX           Float?
  positionY           Float?
  scale               Float?
  aspectRatio         Float?
  chromaKeyEnabled    Boolean   @default(false)
  chromaKeyColor      String?
  chromaKeySimilarity Float?
  chromaKeySmoothness Float?
  flatView            Boolean   @default(false)
  linkEnabled         Boolean   @default(false)
  linkUrl             String?
  order               Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime
  arContent           ArContent @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("media_items")
}

// ─── 포토부스 (pic_) ───

model ImageType {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  images    Image[]

  @@map("pic_image_type")
}

model Image {
  id        Int       @id @default(autoincrement())
  deviceId  String?   @map("device_id") @db.VarChar(64)
  imageType Int       @map("image_type")
  name      String    @db.VarChar(32)
  filename  String    @db.VarChar(64)
  width     Int?
  height    Int?
  left      Int?
  top       Int?
  right     Int?
  bottom    Int?
  priority  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  type      ImageType @relation(fields: [imageType], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("pic_image")
}

model Setting {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(32)
  value       String   @db.VarChar(255)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("pic_Setting")
}

model Device {
  id          Int             @id @default(autoincrement())
  deviceId    String          @unique @map("device_id") @db.VarChar(64)
  name        String          @db.VarChar(128)
  description String?         @db.VarChar(255)
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  settings    DeviceSetting[]
  payments    PayappPayment[]

  @@map("pic_device")
}

model DeviceSetting {
  id          Int      @id @default(autoincrement())
  deviceId    String   @map("device_id") @db.VarChar(64)
  name        String   @db.VarChar(32)
  value       String   @db.VarChar(255)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  device      Device   @relation(fields: [deviceId], references: [deviceId], onDelete: NoAction, onUpdate: NoAction)

  @@unique([deviceId, name], map: "pic_uq_device_setting")
  @@map("pic_device_setting")
}

model AdminAccount {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(64)
  password  String   @db.VarChar(255)
  name      String?  @db.VarChar(64)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("pic_admin_account")
}

model PayappPayment {
  id          Int       @id @default(autoincrement())
  orderId     String    @unique @map("order_id") @db.VarChar(64)
  deviceId    String    @map("device_id") @db.VarChar(64)
  amount      Int
  goodname    String    @db.VarChar(128)
  status      String    @default("pending") @db.VarChar(32)
  payState    String?   @map("pay_state") @db.VarChar(32)
  mulNo       String?   @map("mul_no") @db.VarChar(64)
  userid      String?   @db.VarChar(64)
  var1        String?   @db.VarChar(255)
  var2        String?   @db.VarChar(255)
  rawPayload  String?   @map("raw_payload")
  paidAt      DateTime? @map("paid_at") @db.Timestamp(6)
  cancelledAt DateTime? @map("cancelled_at") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  device      Device    @relation(fields: [deviceId], references: [deviceId], onDelete: NoAction, onUpdate: NoAction)

  @@index([deviceId], map: "pic_ix_payapp_payment_device_id")
  @@index([orderId], map: "pic_ix_payapp_payment_order_id")
  @@map("pic_payapp_payment")
}
