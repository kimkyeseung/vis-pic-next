{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AR-pic",
  "version": "0.1.0",
  "identifier": "net.viswave.arpic",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "node scripts/prepare-tauri.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "비즈웨이브 AR-pic",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["server/*", "server/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["Korean", "English"]
      }
    }
  },
  "plugins": {}
}
