# Prisma (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase Client
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable__xxxxx

# Session/JWT
SESSION_SECRET_KEY=your-session-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# PayApp 결제 연동
PAYAPP_LINKKEY=
PAYAPP_LINKVAL=
PAYAPP_USERID=
PAYAPP_SHOPNAME=AR-pic
PAYAPP_GOODNAME=AR-pic 촬영
PAYAPP_RECVPHONE=
PAYAPP_FEEDBACK_URL=https://your-domain.com/api/payments/feedback
PAYAPP_RETURN_URL=https://your-domain.com/payment/return

# Upload
UPLOAD_DIR=public/static/images
